#include <Arduino.h>

#define LDR_PIN 4
#define BTN_PIN 5

const uint8_t resolutions[] = {9, 10, 11, 12};
const adc_attenuation_t attenuations[] = {ADC_0db, ADC_2_5db, ADC_6db, ADC_11db};
const char* attenuation_names[] = {"ADC_0db", "ADC_2_5db", "ADC_6db", "ADC_11db"};
const double attenuation_max_v[] = {0.8, 1.1, 1.35, 3.1};

void measure(uint8_t resolution, uint8_t atten_index) {
  analogReadResolution(resolution);
  analogSetPinAttenuation(LDR_PIN, attenuations[atten_index]);
  delay(10);

  uint32_t max_raw = (1 << resolution) - 1;

  double sum = 0;
  double sum_sq = 0;
  const uint8_t samples = 10;

  for (uint8_t i = 0; i < samples; i++) {
    uint16_t raw = analogRead(LDR_PIN);
    uint16_t voltage_mv = analogReadMilliVolts(LDR_PIN);
    double voltage_calc = (double)raw / max_raw * attenuation_max_v[atten_index];
    double voltage_mv_v = voltage_mv / 1000.0;
    double error = fabs(voltage_calc - voltage_mv_v) / voltage_mv_v * 100;

    sum += voltage_mv_v;
    sum_sq += voltage_mv_v * voltage_mv_v;

    Serial.printf("  [%u] RAW: %u | Calc: %.3f V | MilliVolts: %.3f V | Deviation: %.2f %%\n",
      i + 1, raw, voltage_calc, voltage_mv_v, error);

    delay(10);
  }

  double mean = sum / samples;
  double variance = (sum_sq / samples) - (mean * mean);
  double stddev = sqrt(variance);

  Serial.printf("  -- Середнє: %.3f V | Стабільність (stddev): %.4f V\n\n", mean, stddev);
}

void run_all() {
  Serial.println("========================================");
  for (uint8_t r = 0; r < 4; r++) {
    for (uint8_t a = 0; a < 4; a++) {
      Serial.printf(">> %u біт | %s | Діапазон: 0 - %.2f V\n",
        resolutions[r], attenuation_names[a], attenuation_max_v[a]);
      measure(resolutions[r], a);
    }
  }
  Serial.println("========================================");
  Serial.println("Готово. Натисніть кнопку для повтору.");
}

void setup() {
  Serial.begin(115200);
  pinMode(BTN_PIN, INPUT);
  Serial.println("Натисніть кнопку для початку вимірювань...");
}

void loop() {
  if (digitalRead(BTN_PIN) == HIGH) {
    delay(50);
    if (digitalRead(BTN_PIN) == HIGH) {
      run_all();
      while (digitalRead(BTN_PIN) == HIGH);
    }
  }
}